# ---- Anime site API (single consolidated backend) ----
# The app now talks to ONE backend: "Anime Invincible API v2".
# The base URL MUST include the trailing `/api` (every route lives under /api).
#   VITE_API_URL    -> the ONLY required variable (primary backend base URL).
#   VITE_API_URL_2  -> optional legacy override (defaults to VITE_API_URL).
#   VITE_API_URL_3  -> optional legacy override (defaults to VITE_API_URL).
# Local dev:  VITE_API_URL=http://localhost:5000/api
# Production: VITE_API_URL=https://your-anime-invincible-api.example.com/api
VITE_API_URL=http://localhost:5000/api
VITE_API_URL_2=
VITE_API_URL_3=

VITE_ANILIST_URL=http://localhost:5000/api
VITE_ANIMEPAHE_API=https://anime-streaming-system-1.onrender.com
VITE_MEGAPLAY_URL=https://megaplayproxy1.vercel.app

# ---- Movies / TV section APIs ----
# NOTE: In PRODUCTION the TMDB key is NO LONGER read from the bundle. The browser
# calls our own /api/tmdb/* edge proxy (functions/api/tmdb/[[path]].js) and the
# key is added server-side. Set it as a Cloudflare Pages SECRET, not here:
#     npx wrangler pages secret put TMDB_API_KEY
#   (or Pages dashboard → Settings → Environment variables → TMDB_API_KEY)
# VITE_TMDB_API_KEY below is only used as a fallback during LOCAL dev.
VITE_TMDB_API_KEY=64b03fca3936439f3d3da531973e5ff9
VITE_VIDEASY_URL=https://player.videasy.to
VITE_EZVIDAPI_URL=https://api.ezvidapi.com
VITE_VIDAPI_URL=https://vaplayer.ru

# ---- Extra video players (Movies/TV + Anime). Leave blank to use defaults. ----
VITE_FILMU_URL=https://embed.filmu.in
VITE_STREAMRIP_URL=https://streamrip.fun
VITE_VIDSRCPM_URL=https://vidsrc.pm
VITE_SCREENSCAPE_URL=https://nxsha.screenscape.me
VITE_VIDNEST_URL=https://vidnest.fun
VITE_VIDCORE_URL=https://vidcore.net
VITE_VIDUP_URL=https://vidup.to
VITE_ANIMEPLAY_URL=https://animeplay.cfd
VITE_TRYEMBED_URL=https://tryembed.us.cc

# ---- Supabase edge cache (fast loads + unbreakable API) ----
# Get these from: Supabase dashboard -> Project Settings -> API
#   Project URL            -> VITE_SUPABASE_URL
#   Project API key (anon)  -> VITE_SUPABASE_ANON_KEY
# Leave blank to disable the cache (site falls back to calling APIs directly).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Supabase Edge Function ONLY (server-side, NEVER in the client) ----
# The service_role key is used by the scheduled refresh function to WRITE the
# cache. Set it as a Supabase function secret, NOT in this client .env.
#   SUPABASE_SERVICE_ROLE_KEY=...
