# ---- Anime site APIs (3 separate deployments to avoid rate limits) ----
# Each anime PAGE uses its own API deployment:
#   VITE_API_URL    -> HOME  page  (anime-details-api)
#   VITE_API_URL_2  -> INFO  page  (anime-details-api-2)
#   VITE_API_URL_3  -> WATCH page  (anime-details-api-3)
# If _2 / _3 are left blank, the app falls back to VITE_API_URL so it keeps
# working until all three are configured in Cloudflare env vars.
VITE_API_URL=https://anime-details-api.vercel.app/api
VITE_API_URL_2=https://anime-details-api-2.vercel.app/api
VITE_API_URL_3=https://anime-details-api-3.vercel.app/api

VITE_ANILIST_URL=https://anime-details-api.vercel.app/api
VITE_ANIMEPAHE_API=https://anime-streaming-system-1.onrender.com
VITE_MEGAPLAY_URL=https://megaplayproxy1.vercel.app

# ---- Movies / TV section APIs ----
VITE_TMDB_API_KEY=64b03fca3936439f3d3da531973e5ff9
VITE_VIDEASY_URL=https://player.videasy.to
VITE_EZVIDAPI_URL=https://api.ezvidapi.com
VITE_VIDAPI_URL=https://vaplayer.ru

# ---- Supabase edge cache (fast loads + unbreakable API) ----
# Get these from: Supabase dashboard -> Project Settings -> API
#   Project URL            -> VITE_SUPABASE_URL
#   Project API key (anon)  -> VITE_SUPABASE_ANON_KEY
# Leave blank to disable the cache (site falls back to calling APIs directly).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Supabase Edge Function ONLY (server-side, NEVER in the client) ----
# The service_role key is used by the scheduled refresh function to WRITE the
# cache. Set it as a Supabase function secret, NOT in this client .env.
#   SUPABASE_SERVICE_ROLE_KEY=...
