# Cloudflare Pages headers — serve sitemaps as XML and cache static assets.
# This file is optional and Cloudflare-safe (ignored by other hosts).
/sitemap.xml
  Content-Type: application/xml; charset=utf-8
/sitemap-*.xml
  Content-Type: application/xml; charset=utf-8
/robots.txt
  Content-Type: text/plain; charset=utf-8
/assets/*
  Cache-Control: public, max-age=31536000, immutable
